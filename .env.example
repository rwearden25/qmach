# ── Required ──────────────────────────────────
# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Mapbox public token (get from account.mapbox.com)
MAPBOX_TOKEN=pk.eyJ1...

# ── Optional ──────────────────────────────────
# Port (Railway sets this automatically)
PORT=3000

# Railway volume mount path (Railway sets this automatically)
# RAILWAY_VOLUME_MOUNT_PATH=/data

# ── Stripe billing (optional — leave unset to disable /billing) ──
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_or_test_...
# Webhook signing secret from https://dashboard.stripe.com/webhooks
# Point the webhook endpoint at: https://YOUR_HOST/api/stripe/webhook
# Subscribe to: checkout.session.completed, customer.subscription.*, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Pro plan (e.g. price_1Rxxx). Create a Product + recurring
# Price in Stripe → copy the price_xxx ID here.
STRIPE_PRICE_PRO_MONTHLY=price_...
# Optional: public base URL for Stripe success/cancel redirects. If unset,
# we build the URL from the inbound request (req.protocol + req.host).
# APP_BASE_URL=https://pquote.ai
