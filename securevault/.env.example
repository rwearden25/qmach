# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ─────────────────────────────────────────────────────────────────
# Full Prisma connection URL
DATABASE_URL=postgresql://vault:changeme@localhost:5432/securevault
# Raw password used by the db service in docker-compose
DB_PASSWORD=changeme

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM contents (newlines replaced with \n) below.
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Object Storage (MinIO / S3-compatible) ───────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=vault-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ─── TOTP / MFA ───────────────────────────────────────────────────────────────
TOTP_ISSUER=SecureVault
# 32-byte hex string — generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_STRING
